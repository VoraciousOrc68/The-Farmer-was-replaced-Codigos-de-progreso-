clear()
while True:
	for i in range(get_world_size()):	
		plant(Entities.Tree)
		if can_harvest() and get_entity_type() == Entities.Tree:
			harvest()
			plant(Entities.Tree)
			move(North)
		else:
			move(North)
		if can_harvest() and get_entity_type() == Entities.Grass:
			harvest()
			plant(Entities.Grass)
		move(North)
	move(East)
	move(North)		
