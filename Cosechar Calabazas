clear()
x, y = get_pos_x(), get_pos_y()
while True:
	for i in range(get_world_size()+5):
		if get_ground_type() == Grounds.Grassland:
			till()
			plant(Entities.Pumpkin)
			move(North)
			
		elif get_ground_type() == Grounds.Soil:
			plant(Entities.Pumpkin)
			move(North)
		
