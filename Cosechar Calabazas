			plant(Entities.Pumpkin)
			move(North)


			if y == 0 and x in range(0, 6):
				move(East)
			else:
				move(North)
		if not can_harvest() and get_entity_type() == Entities.Pumpkin :
				plant(Entities.Pumpkin)
				move(North)
					
			
